---
import {
	badgeLabel,
	jacuzziEmoji,
	amenidadIcon,
	formatCOP,
} from "@lib/formatter";
import { getCollection, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import BookingSidebar from "@components/booking/BookingSidebar.tsx";
import { getImageUrl } from "@lib/utils.ts";

export async function getStaticPaths() {
	const alojamientos = await getCollection("alojamientos");
	return alojamientos.map((alojamiento) => ({
		params: { slug: alojamiento.id },
		props: { alojamiento },
	}));
}

const { alojamiento } = Astro.props;
const { Content } = await render(alojamiento);
const base = import.meta.env.BASE_URL;
---

<MainLayout
	title={`${alojamiento.data.nombre} | Villa del Eden`}
	description={alojamiento.data.resumen ||
		`Descubre ${alojamiento.data.nombre} en Villa del Eden.`}
	image={alojamiento.data.imagen}
>
	<!-- Hero Image Banner -->
	<header
		class="relative h-[60vh] min-h-[400px] max-h-[600px] bg-cover bg-center flex items-end pb-16"
		style={`background-image: url('${getImageUrl(alojamiento.data.imagen)}')`}
	>
		<!-- Overlay -->
		<div
			class="absolute inset-0 z-1 bg-linear-to-t from-forest/95 via-forest/40 to-black/10"
		>
		</div>

		<!-- Content -->
		<div class="relative z-2 text-white container" data-aos="fade-up">
			<span class={`badge badge-${alojamiento.data.tipo}`}>
				{badgeLabel(alojamiento.data.tipo)}
			</span>

			<h1
				class="text-white! mb-2 drop-shadow-[0_2px_10px_rgba(0,0,0,0.2)] md:text-[2.2rem]"
			>
				{alojamiento.data.nombre}
			</h1>

			<p
				class="text-[1.1rem] opacity-90 flex items-center flex-wrap gap-3"
			>
				<span>👥 {alojamiento.data.capacidad} personas</span>
				<span>&bull;</span>
				<span>
					{jacuzziEmoji(alojamiento.data.jacuzzi)} Jacuzzi {
						alojamiento.data.jacuzzi
					}
				</span>
			</p>
		</div>
	</header>

	<div class="detail-container container">
		<!-- Content Column -->
		<div class="main-content">
			<div class="content-body" data-aos="fade-up">
				<Content />
			</div>

			{
				alojamiento.data.amenidades &&
					alojamiento.data.amenidades.length > 0 && (
						<div class="amenities-section" data-aos="fade-up">
							<h2>Amenidades</h2>
							<ul class="amenities-list">
								{alojamiento.data.amenidades.map(
									(amenidad: string) => (
										<li>
											<span class="amenity-icon">
												{amenidadIcon(amenidad)}
											</span>{" "}
											{amenidad}
										</li>
									),
								)}
							</ul>
						</div>
					)
			}

			{
				alojamiento.data.galeria &&
					alojamiento.data.galeria.length > 0 && (
						<div class="gallery-section" data-aos="fade-up">
							<h2>Galería</h2>
							<div class="photo-grid">
								{alojamiento.data.galeria.map(
									(img: string, idx: number) => (
										<img
											src={getImageUrl(img)}
											alt={`Foto de ${alojamiento.data.nombre} ${idx + 1}`}
											loading="lazy"
										/>
									),
								)}
							</div>
						</div>
					)
			}
		</div>

		<!-- Sidebar with Booking Widget -->
		<BookingSidebar
			precio={alojamiento.data.precio}
			capacidad={alojamiento.data.capacidad}
			nombre={alojamiento.data.nombre}
			precioMax={alojamiento.data.precioMax}
		/>
	</div>
</MainLayout>

<style>
	.badge {
		display: inline-block;
		padding: 0.35rem 1rem;
		border-radius: 50px;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.5px;
		margin-bottom: 1rem;
		text-transform: uppercase;
	}
	.badge-suite {
		background: rgba(200, 151, 62, 0.95);
		color: white;
	}
	.badge-glamping {
		background: rgba(26, 58, 42, 0.95);
		color: white;
		border: 1px solid rgba(255, 255, 255, 0.2);
	}
	.badge-cabana {
		background: rgba(74, 103, 65, 0.95);
		color: white;
	}

	.meta-dot {
		opacity: 0.5;
	}

	/* Main Layout */
	.detail-container {
		display: grid;
		grid-template-columns: 1fr 380px;
		gap: 4rem;
		padding-top: 4rem;
		padding-bottom: 6rem;
		align-items: start;
	}

	/* Typography & Markdown Content */
	.content-body {
		font-size: 1.1rem;
		line-height: 1.8;
		color: var(--color-forest);
		margin-bottom: 4rem;
	}

	.content-body :global(h2),
	.content-body :global(h3) {
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		color: var(--color-forest);
	}

	.content-body :global(p) {
		margin-bottom: 1.5rem;
	}

	.content-body :global(ul) {
		padding-left: 1.5rem;
		margin-bottom: 1.5rem;
	}

	.content-body :global(li) {
		margin-bottom: 0.5rem;
	}

	/* Amenities */
	.amenities-section h2,
	.gallery-section h2 {
		font-size: 2rem;
		margin-bottom: 1.5rem;
		padding-bottom: 1rem;
		border-bottom: 1px solid var(--color-mist);
	}

	.amenities-list {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
		gap: 1.25rem;
		list-style: none;
		padding: 0;
		margin: 0 0 4rem 0;
	}

	.amenities-list li {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-weight: 500;
	}

	.amenity-icon {
		background: var(--color-mist);
		width: 38px;
		height: 38px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		font-size: 1.1rem;
	}

	/* Gallery */
	.photo-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
	}

	.photo-grid img {
		width: 100%;
		height: 280px;
		object-fit: cover;
		border-radius: 12px;
		transition: transform 0.3s;
	}

	.photo-grid img:first-child {
		grid-column: 1 / -1;
		height: 400px;
	}

	.photo-grid img:hover {
		transform: scale(1.02);
	}

	/* Responsive */
	@media (max-width: 1024px) {
		.detail-container {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.photo-grid img {
			height: 200px;
		}

		.photo-grid img:first-child {
			height: 300px;
		}
	}

	@media (max-width: 768px) {
		.detail-container {
			padding-top: 2rem;
		}

		.photo-grid {
			grid-template-columns: 1fr;
		}

		.photo-grid img,
		.photo-grid img:first-child {
			height: 250px;
		}
	}
</style>
