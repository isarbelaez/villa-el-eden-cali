---
interface Props {
	title: string;
	image: string;
	price: number;
	jacuzziType: string;
}

const { title, image, price, jacuzziType } = Astro.props;

// format price as COP
const formattedPrice = new Intl.NumberFormat('es-CO', {
	style: 'currency',
	currency: 'COP',
	minimumFractionDigits: 0
}).format(price);
---

<div class="card" data-aos="fade-up">
	<div class="card-image">
		<img src={image} alt={`Foto de ${title}`} loading="lazy" />
	</div>
	<div class="card-content">
		<h3>{title}</h3>
		<p class="jacuzzi">
			<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" class="icon" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12c-2.66 0-4.32-2-6-4s-3.34-4-6-4-4.32 2-6 4-3.34 4-6 4"></path><path d="M22 18c-2.66 0-4.32-2-6-4s-3.34-4-6-4-4.32 2-6 4-3.34 4-6 4"></path></svg>
			Jacuzzi {jacuzziType}
		</p>
		<p class="price">{formattedPrice} / noche</p>
	</div>
</div>

<style>
	.card {
		background: var(--color-white);
		border-radius: 8px;
		overflow: hidden;
		box-shadow: var(--box-shadow);
		transition: all 0.3s ease;
	}
	
	.card:hover {
		transform: translateY(-5px);
		box-shadow: var(--box-shadow-hover);
	}

	.card-image {
		width: 100%;
		height: 250px;
		overflow: hidden;
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.card:hover .card-image img {
		transform: scale(1.05);
	}

	.card-content {
		padding: 1.5rem;
		text-align: center;
	}

	.card-content h3 {
		font-size: 1.5rem;
		margin-bottom: 0.5rem;
	}

	.jacuzzi {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		color: var(--color-sage);
		font-weight: 500;
		margin-bottom: 1rem;
	}

	.price {
		font-size: 1.25rem;
		font-weight: 600;
		color: var(--color-forest);
		margin: 0;
	}
</style>
