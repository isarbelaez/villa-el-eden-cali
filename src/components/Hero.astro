---
import CTAButton from './CTAButton.astro';

interface Props {
	title: string;
	subtitle: string;
	image: string;
	ctaText?: string;
	ctaLink?: string;
}

const { title, subtitle, image, ctaText = 'Haz tu reserva', ctaLink = '/ejemplo-villa-eucalipto-y-romero-glamping/reservas' } = Astro.props;
---

<section class="hero" style={`background-image: url('${image}')`}>
	<div class="hero-overlay"></div>
	<div class="container hero-content" data-aos="fade-up">
		<h1>{title}</h1>
		<p class="subtitle">{subtitle}</p>
		<CTAButton text={ctaText} href={ctaLink} />
	</div>
</section>

<style>
	.hero {
		position: relative;
		height: 100vh;
		min-height: 600px;
		background-size: cover;
		background-position: center;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.hero-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(to bottom, rgba(26,58,42,0.4) 0%, rgba(26,58,42,0.9) 100%);
	}

	.hero-content {
		position: relative;
		z-index: 10;
		text-align: center;
		color: var(--color-white);
		max-width: 800px;
	}

	h1 {
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		color: var(--color-white);
		margin-bottom: 1rem;
		text-transform: uppercase;
		letter-spacing: 2px;
	}

	.subtitle {
		font-family: var(--font-display);
		font-size: clamp(1.2rem, 3vw, 1.8rem);
		font-style: italic;
		margin-bottom: 2.5rem;
		color: var(--color-gold);
	}
</style>
