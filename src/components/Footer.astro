---
const today = new Date();
---

<footer class="footer">
	<div class="container footer-content">
		<div class="footer-info">
			<h3>Villa del Eden</h3>
			<p>Glamping & Cabañas</p>
			<p class="tagline">Donde la tranquilidad existe</p>
		</div>

		<div class="footer-links">
			<h4>Enlaces</h4>
			<ul>
				<li><a href={`${import.meta.env.BASE_URL}/`}>Inicio</a></li>
				<li>
					<a href={`${import.meta.env.BASE_URL}/quienes-somos`}
						>Quiénes Somos</a
					>
				</li>
				<li>
					<a href={`${import.meta.env.BASE_URL}/reservas`}
						>Reservas</a>
				</li>
			</ul>
		</div>

		<div class="footer-contact">
			<h4>Contacto</h4>
			<p><strong>Ingreso:</strong> 3:00 p.m.</p>
			<p><strong>Salida:</strong> 11:00 a.m. (del día siguiente)</p>
			<div class="social-links">
				<a href="#" aria-label="WhatsApp">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><path
							d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
						></path></svg
					>
				</a>
				<a href="#" aria-label="Instagram">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><rect x="2" y="2" width="20" height="20" rx="5" ry="5"
						></rect><path
							d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
						></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"
						></line></svg
					>
				</a>
			</div>
		</div>
	</div>

	<div class="footer-bottom">
		<p>
			&copy; {today.getFullYear()} Villa del Eden. Todos los derechos reservados.
		</p>
	</div>
</footer>

<style>
	.footer {
		background-color: var(--color-forest);
		color: var(--color-mist);
		padding: 4rem 0 0 0;
	}

	.footer-content {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 3rem;
		padding-bottom: 3rem;
	}

	h3 {
		color: var(--color-gold);
		margin-bottom: 0.5rem;
		font-size: 1.5rem;
	}

	h4 {
		color: var(--color-white);
		margin-bottom: 1.5rem;
		font-size: 1.25rem;
	}

	.tagline {
		font-style: italic;
		color: var(--color-gold);
		opacity: 0.8;
	}

	ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	ul li {
		margin-bottom: 0.8rem;
	}

	a {
		color: var(--color-mist);
	}

	a:hover {
		color: var(--color-gold);
	}

	.footer-contact p {
		margin-bottom: 0.5rem;
	}

	.social-links {
		display: flex;
		gap: 1.5rem;
		margin-top: 1.5rem;
	}

	.social-links a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		background-color: rgba(255, 255, 255, 0.1);
		border-radius: 50%;
		transition: all 0.3s ease;
	}

	.social-links a:hover {
		background-color: var(--color-gold);
		color: var(--color-forest);
		transform: translateY(-3px);
	}

	.footer-bottom {
		background-color: rgba(0, 0, 0, 0.2);
		text-align: center;
		padding: 1.5rem;
		font-size: 0.9rem;
		opacity: 0.8;
	}

	.footer-bottom p {
		margin: 0;
	}

	@media (max-width: 768px) {
		.footer-content {
			grid-template-columns: 1fr;
			text-align: center;
		}

		.social-links {
			justify-content: center;
		}
	}
</style>
