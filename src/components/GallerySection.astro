---
interface GalleryItem {
	id: string;
	nombre: string;
	imagen: string;
	precio: number;
	jacuzzi: string;
	tipo: string;
	capacidad: number;
	resumen?: string;
	amenidades?: string[];
}

interface Props {
	alojamientos: GalleryItem[];
}

const { alojamientos } = Astro.props;
---

<section class="gallery-section" id="galeria-alojamientos">
	<div class="container">
		<div class="gallery-header" data-aos="fade-up">
			<h2>Alojamientos más visitados</h2>
			<p>
				Descubre nuestros refugios de lujo en la naturaleza y encuentra
				el perfecto para tu escapada.
			</p>
		</div>

		<div class="gallery-grid" id="gallery-grid">
			{
				alojamientos.map((aloj) => (
					<article
						class="gallery-card"
						data-tipo={aloj.tipo}
						data-jacuzzi={aloj.jacuzzi}
						data-precio={aloj.precio}
						data-aos="fade-up"
					>
						<div class="card-img-wrap">
							<img
								src={aloj.imagen}
								alt={`Foto de ${aloj.nombre} - alojamiento glamping`}
								loading="lazy"
							/>
							<span class={`badge badge-${aloj.tipo}`}>
								{aloj.tipo === "suite"
									? "Suite"
									: aloj.tipo === "glamping"
										? "Glamping"
										: "Cabaña"}
							</span>
						</div>
						<div class="card-body">
							<h3>{aloj.nombre}</h3>
							{aloj.resumen && (
								<p class="card-resumen">{aloj.resumen}</p>
							)}
							<div class="card-meta">
								<span class="meta-item">
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="16"
										height="16"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
									>
										<>
											<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
											<circle cx="9" cy="7" r="4" />
											<path d="M23 21v-2a4 4 0 0 0-3-3.87" />
											<path d="M16 3.13a4 4 0 0 1 0 7.75" />
										</>
									</svg>
									{aloj.capacidad} personas
								</span>
								<span class="meta-item">
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="16"
										height="16"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
									>
										<>
											<path d="M22 12c-2.66 0-4.32-2-6-4s-3.34-4-6-4-4.32 2-6 4-3.34 4-6 4" />
											<path d="M22 18c-2.66 0-4.32-2-6-4s-3.34-4-6-4-4.32 2-6 4-3.34 4-6 4" />
										</>
									</svg>
									Jacuzzi {aloj.jacuzzi}
								</span>
							</div>
							{aloj.amenidades && aloj.amenidades.length > 0 && (
								<div class="amenidades-chips">
									{aloj.amenidades.slice(0, 3).map((a) => (
										<span class="chip">{a}</span>
									))}
									{aloj.amenidades.length > 3 && (
										<span class="chip chip-more">
											+{aloj.amenidades.length - 3} más
										</span>
									)}
								</div>
							)}
							<div class="card-footer">
								<div class="precio-wrap">
									<span class="precio">
										{new Intl.NumberFormat("es-CO", {
											style: "currency",
											currency: "COP",
											minimumFractionDigits: 0,
										}).format(aloj.precio)}
									</span>
									<span class="precio-label">
										/ noche para 2
									</span>
								</div>
								<a
									href={`${import.meta.env.BASE_URL}/reservas?alojamiento=${encodeURIComponent(aloj.nombre)}`}
									class="card-reserve-btn"
									aria-label={`Reservar ${aloj.nombre}`}
								>
									Reservar
								</a>
							</div>
						</div>
					</article>
				))
			}
		</div>

		<div
			class="no-results"
			id="no-results"
			style="display:none;"
			data-aos="fade-in"
		>
			<p>
				No se encontraron alojamientos con esos filtros. <button
					id="clear-filters">Ver todos</button
				>
			</p>
		</div>
	</div>
</section>

<style>
	.gallery-section {
		padding: 4rem 0 5rem;
		background-color: var(--color-white);
	}

	.gallery-header {
		text-align: center;
		margin-bottom: 3rem;
	}

	.gallery-header h2 {
		font-size: clamp(1.8rem, 4vw, 2.8rem);
		margin-bottom: 0.75rem;
	}

	.gallery-header p {
		color: #666;
		max-width: 500px;
		margin: 0 auto;
		font-size: 1rem;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
		gap: 2rem;
	}

	/* Card */
	.gallery-card {
		background: white;
		border-radius: 20px;
		overflow: hidden;
		box-shadow: 0 4px 20px rgba(26, 58, 42, 0.07);
		transition:
			transform 0.35s ease,
			box-shadow 0.35s ease;
	}

	.gallery-card:hover {
		transform: translateY(-8px);
		box-shadow: 0 16px 40px rgba(26, 58, 42, 0.13);
	}

	.card-img-wrap {
		position: relative;
		height: 220px;
		overflow: hidden;
	}

	.card-img-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
		border-radius: 0;
	}

	.gallery-card:hover .card-img-wrap img {
		transform: scale(1.07);
	}

	/* Badges */
	.badge {
		position: absolute;
		top: 14px;
		left: 14px;
		padding: 0.25rem 0.75rem;
		border-radius: 50px;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		backdrop-filter: blur(4px);
	}

	.badge-suite {
		background: rgba(200, 151, 62, 0.9);
		color: white;
	}
	.badge-glamping {
		background: rgba(26, 58, 42, 0.9);
		color: white;
	}
	.badge-cabana {
		background: rgba(74, 103, 65, 0.9);
		color: white;
	}

	/* Body */
	.card-body {
		padding: 1.5rem;
	}

	.card-body h3 {
		font-size: 1.3rem;
		margin-bottom: 0.4rem;
	}

	.card-resumen {
		font-size: 0.9rem;
		color: #777;
		margin-bottom: 1rem;
		line-height: 1.5;
	}

	.card-meta {
		display: flex;
		gap: 1.2rem;
		margin-bottom: 1rem;
	}

	.meta-item {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.85rem;
		color: var(--color-sage);
		font-weight: 500;
	}

	/* Amenidades */
	.amenidades-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-bottom: 1.25rem;
	}

	.chip {
		background: var(--color-mist);
		color: var(--color-forest);
		padding: 0.2rem 0.65rem;
		border-radius: 50px;
		font-size: 0.75rem;
		font-weight: 500;
		white-space: nowrap;
	}

	.chip-more {
		background: transparent;
		border: 1px solid var(--color-mist);
		color: #999;
	}

	/* Footer */
	.card-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		border-top: 1px solid var(--color-mist);
		padding-top: 1rem;
		gap: 1rem;
	}

	.precio-wrap {
		display: flex;
		flex-direction: column;
		line-height: 1.2;
	}

	.precio {
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--color-forest);
		font-family: var(--font-display);
	}

	.precio-label {
		font-size: 0.75rem;
		color: #999;
	}

	.card-reserve-btn {
		background-color: var(--color-forest);
		color: white;
		padding: 0.55rem 1.2rem;
		border-radius: 50px;
		font-size: 0.85rem;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.3s ease;
		white-space: nowrap;
	}

	.card-reserve-btn:hover {
		background-color: var(--color-gold);
		color: white;
	}

	/* No results */
	.no-results {
		text-align: center;
		padding: 3rem;
		color: #888;
	}

	.no-results button {
		background: none;
		border: none;
		color: var(--color-gold);
		font-weight: 600;
		cursor: pointer;
		text-decoration: underline;
		font-family: var(--font-body);
	}

	.gallery-card.hidden {
		display: none;
	}

	@media (max-width: 768px) {
		.gallery-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	function filterCards(detail: {
		tipo: string;
		jacuzzi: string;
		precio: string;
	}) {
		const cards = document.querySelectorAll<HTMLElement>(".gallery-card");
		let visible = 0;

		cards.forEach((card) => {
			const matches =
				(!detail.tipo || card.dataset.tipo === detail.tipo) &&
				(!detail.jacuzzi || card.dataset.jacuzzi === detail.jacuzzi) &&
				(!detail.precio || card.dataset.precio === detail.precio);

			if (matches) {
				card.classList.remove("hidden");
				visible++;
			} else {
				card.classList.add("hidden");
			}
		});

		const noResults = document.getElementById("no-results");
		if (noResults)
			noResults.style.display = visible === 0 ? "block" : "none";
	}

	// Listen to filter events dispatched from SearchBar
	window.addEventListener("filterAlojamientos", (e: Event) => {
		const customEvt = e as CustomEvent;
		filterCards(customEvt.detail);
	});

	// Clear filters button
	document.getElementById("clear-filters")?.addEventListener("click", () => {
		filterCards({ tipo: "", jacuzzi: "", precio: "" });
		// Reset selects in SearchBar
		(document.getElementById("search-tipo") as HTMLSelectElement).value =
			"";
		(document.getElementById("search-jacuzzi") as HTMLSelectElement).value =
			"";
		(document.getElementById("search-precio") as HTMLSelectElement).value =
			"";
	});
</script>
